# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/rblxdash?schema=public"

# ─── Clerk (auth) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Stripe ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_PRO=price_xxx
STRIPE_PRICE_STUDIO=price_xxx

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Roblox OAuth ───────────────────────────────────────────────────────────
ROBLOX_OAUTH_CLIENT_ID=
ROBLOX_OAUTH_CLIENT_SECRET=
ROBLOX_OAUTH_SCOPES=openid profile email credentials universe:read universe-datastores:read universe-datastores:write user.inventory-item:read
ROBLOX_OAUTH_PUBLIC_ENABLED=true
# 64-char hex key for AES-256-GCM encryption of OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROBLOX_OAUTH_ENCRYPTION_KEY=

# ─── Encryption ─────────────────────────────────────────────────────────────
# 64-char hex key for AES-256-GCM encryption of Open Cloud API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPEN_CLOUD_API_KEY_ENCRYPTION_KEY=

# ─── Email (Resend) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxx

# ─── Cron ───────────────────────────────────────────────────────────────────
# Bearer token for cron endpoint auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── Maintenance ──────────────────────────────────────────────────────────
# Set to "true" to enable maintenance mode (503 for all routes except /api/health)
MAINTENANCE_MODE=false
# Optional: custom message shown during maintenance
# MAINTENANCE_MESSAGE="We're upgrading RblxDash. Back in 30 minutes."
# Optional: comma-separated IPs that bypass maintenance mode
# MAINTENANCE_ALLOWED_IPS=1.2.3.4,5.6.7.8
