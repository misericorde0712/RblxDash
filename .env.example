# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/robloxdash?schema=public"

# ─── Clerk (auth) ───────────────────────────────────────────────────────────
# Get these from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE
CLERK_SECRET_KEY=sk_test_YOUR_KEY_HERE
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ─── Stripe ─────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_KEY_HERE

# Stripe Price IDs (create these in your Stripe dashboard → Products)
STRIPE_PRICE_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_STUDIO=price_YOUR_STUDIO_PRICE_ID

# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Roblox OAuth ───────────────────────────────────────────────────────────
# Get these from https://create.roblox.com → Credentials → OAuth 2.0 Applications
ROBLOX_OAUTH_CLIENT_ID=YOUR_CLIENT_ID
ROBLOX_OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET
ROBLOX_OAUTH_SCOPES=openid profile asset:read asset:write universe-messaging-service:publish user.advanced:read
ROBLOX_OAUTH_PUBLIC_ENABLED=true
# 64-char hex key for AES-256-GCM encryption of OAuth tokens
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ROBLOX_OAUTH_ENCRYPTION_KEY=

# ─── Encryption ─────────────────────────────────────────────────────────────
# 64-char hex key for AES-256-GCM encryption of Open Cloud API keys
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OPEN_CLOUD_API_KEY_ENCRYPTION_KEY=

# ─── Email (Resend) ──────────────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Bearer token for cron endpoint auth
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=

# ─── Maintenance ─────────────────────────────────────────────────────────────
# Set to "true" to enable maintenance mode (503 for all routes except /api/health)
MAINTENANCE_MODE=false
# Optional: custom message shown during maintenance
# MAINTENANCE_MESSAGE="We're upgrading RblxDash. Back in 30 minutes."
# Optional: comma-separated IPs that bypass maintenance mode
# MAINTENANCE_ALLOWED_IPS=1.2.3.4,5.6.7.8

# ─── Upstash Redis (rate limiting) ──────────────────────────────────────────
# Get these from https://console.upstash.com → Redis → REST API
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ─── Sentry (error tracking) ────────────────────────────────────────────────
# Get your DSN from https://sentry.io → Project Settings → Client Keys
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

NODE_ENV=development
